# Anthropic
ANTHROPIC_API_KEY=
# claude-sonnet-4-20250514 retired 2026-06-15 — use claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI image generation (content drafts)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
CONTENT_MAX_IMAGES=3
IMAGE_GENERATION_ENABLED=true

# Max content drafts generating at the same time
CONTENT_GENERATION_CONCURRENCY=3

# WordPress Application Passwords (one per brand)
WP_APP_PASSWORD_AXXIOM=
WP_APP_PASSWORD_AMERITEX=
WP_APP_PASSWORD_ARIZONA_ES=
WP_APP_PASSWORD_LIFTECH=
WP_APP_PASSWORD_MOTION=
WP_APP_PASSWORD_QUALITY=
WP_APP_PASSWORD_EVOLUTION=
WP_APP_PASSWORD_IRONHAWK=

# WordPress usernames (defaults to 'admin' if not set)
WP_USERNAME_AXXIOM=admin
WP_USERNAME_AMERITEX=admin

# WordPress post author per brand (numeric user ID; 0/unset = posts belong to
# the application-password account). Find the ID in WP Admin → Users → click
# the user → user_id=N in the URL. The API account needs permission to assign
# authors (Administrator/Editor). Applied on create AND update, so
# republishing an existing post also fixes its author.
# e.g. WP_AUTHOR_ID_QUALITY=9   (Eric Amundson on qualityelevator.com)
WP_AUTHOR_ID_QUALITY=0
WP_AUTHOR_ID_AMERITEX=0

# Database — Supabase PostgreSQL (same project as auth)
# Project Settings → Database → Connection string → Session pooler (port 5432)
# Use postgresql:// or postgresql+asyncpg:// — both work (asyncpg is added automatically)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Transaction pooler (port 6543) also works; prepared statement cache is disabled automatically
DB_SCHEMA=aeo

# Tracking / citations
# Production: use none until GEO/AEO Tracker is deployed; then geo_aeo
# Citation monitoring: geo_aeo (recommended when tracker deployed), peec, none, auto
CITATION_PROVIDER=geo_aeo
GEO_AEO_TRACKER_URL=http://localhost:3000
GEO_AEO_PROVIDERS=perplexity,chatgpt,google_ai
GEO_AEO_CONCURRENCY=2
CITATION_SAMPLE_RUNS=3
PEEC_API_KEY=

# Weekly content worker — max queue items per Monday run
WEEKLY_CONTENT_BATCH_SIZE=5

GOOGLE_SERVICE_ACCOUNT_JSON=
BING_API_KEY=

# Supabase Auth (same project as DATABASE_URL)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=

# Notifications
SLACK_WEBHOOK_URL=
# Production: set to your Netlify site URL (also auto-added to CORS allow list).
FRONTEND_URL=http://localhost:5173

# App
# Local dev: ENVIRONMENT=development (allows any localhost port for CORS).
# Railway/production: set ENVIRONMENT=production.
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
# Production: comma-separated list of allowed frontend origins (your Netlify URL).
# e.g. CORS_ORIGINS=https://axxiom-aeo.netlify.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: regex to also allow Netlify deploy previews / branch deploys.
# e.g. CORS_ORIGIN_REGEX=https://([a-z0-9-]+--)?axxiom-aeo\.netlify\.app
CORS_ORIGIN_REGEX=

# NOTE: Railway provides PORT automatically — do not set it.
# Start command (railway.json / Procfile): uvicorn app.main:app --host 0.0.0.0 --port $PORT
