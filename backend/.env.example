# Anthropic
ANTHROPIC_API_KEY=
# claude-sonnet-4-20250514 retired 2026-06-15 — use claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6
# Optional: route Claude through Microsoft Foundry's Anthropic endpoint (same
# Messages API). Set the base URL below and put your AZURE/Foundry key in
# ANTHROPIC_API_KEY; set CLAUDE_MODEL to the Foundry deployment name. Leave the
# base URL blank to call api.anthropic.com directly.
# ANTHROPIC_BASE_URL=https://<resource-name>.services.ai.azure.com/anthropic
ANTHROPIC_BASE_URL=

# Article image generation (content drafts)
# IMAGE_PROVIDER: ideogram (Ideogram 3.0; default), fal (fal.ai Flux 2 Pro /
# Imagen 4), or openai (gpt-image). If the chosen provider has no key, the
# pipeline falls back to any other configured provider so images never stop.
IMAGE_PROVIDER=ideogram
CONTENT_MAX_IMAGES=3
IMAGE_GENERATION_ENABLED=true

# Ideogram — key from the Ideogram dashboard (store as secret). Sent in the
# Api-Key header. Defaults are tuned for quality/realism:
#  rendering_speed QUALITY = best fidelity (drop to DEFAULT to cut cost/latency).
#  style_type REALISTIC = photographic look. magic_prompt OFF = use our detailed
#  briefs verbatim. aspect_ratio is a WxH ratio: 16x10, 16x9, 4x3, 1x1, 9x16, etc.
IDEOGRAM_API_KEY=
IDEOGRAM_ENDPOINT=https://api.ideogram.ai/v1/ideogram-v3/generate
IDEOGRAM_ASPECT_RATIO=16x10
IDEOGRAM_RENDERING_SPEED=QUALITY
IDEOGRAM_STYLE_TYPE=REALISTIC
IDEOGRAM_MAGIC_PROMPT=OFF

# fal.ai — alternative provider (IMAGE_PROVIDER=fal). Key from fal.ai dashboard.
FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/flux-2-pro
FAL_IMAGE_SIZE=landscape_4_3
FAL_OUTPUT_FORMAT=jpeg

# OpenAI images (fallback / IMAGE_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_QUALITY=medium

# Max content drafts generating at the same time
CONTENT_GENERATION_CONCURRENCY=3

# WordPress Application Passwords (one per brand)
WP_APP_PASSWORD_AXXIOM=
WP_APP_PASSWORD_AMERITEX=
WP_APP_PASSWORD_ARIZONA_ES=
WP_APP_PASSWORD_LIFTECH=
WP_APP_PASSWORD_QUALITY=

# WordPress usernames (defaults to 'admin' if not set)
WP_USERNAME_AXXIOM=admin
WP_USERNAME_AMERITEX=admin

# Discussion policy applied to every published post (and re-applied on
# update), overriding each site's Settings -> Discussion default.
# Both default false. Comments off = no spam-bot comments on auto-posts.
# Pings off = no inbound trackback spam (ping_status=open does NOT earn
# backlinks — that's a separate outbound setting — and is a dead SEO/AEO
# signal). Flip WP_ALLOW_PINGS=true only to run a deliberate experiment.
# Backfill existing posts: python scripts/lock_discussion.py --apply
WP_ALLOW_COMMENTS=false
WP_ALLOW_PINGS=false

# WordPress post author per brand (numeric user ID; 0/unset = posts belong to
# the application-password account). Find the ID in WP Admin → Users → click
# the user → user_id=N in the URL. The API account needs permission to assign
# authors (Administrator/Editor). Applied on create AND update, so
# republishing an existing post also fixes its author.
# Authors — all 5 brands verified live 2026-07-06: quality=Eric Amundson (9),
# liftech=Ian Post (9), arizona_es=Taylor Tack (9), axxiom=Robin Volesky (16),
# ameritex=Jennifer Gonzales (9).
WP_AUTHOR_ID_QUALITY=9
WP_AUTHOR_ID_LIFTECH=9
WP_AUTHOR_ID_ARIZONA_ES=9
WP_AUTHOR_ID_AMERITEX=9
WP_AUTHOR_ID_AXXIOM=16

# Database — Supabase PostgreSQL (same project as auth)
# Project Settings → Database → Connection string → Session pooler (port 5432)
# Use postgresql:// or postgresql+asyncpg:// — both work (asyncpg is added automatically)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Transaction pooler (port 6543) also works; prepared statement cache is disabled automatically
DB_SCHEMA=aeo

# Tracking / citations
# Provider: brightdata (direct Bright Data AI-search APIs, recommended),
# geo_aeo (self-hosted tracker app), peec (legacy), none, or auto.
CITATION_PROVIDER=brightdata

# Bright Data native AI-search APIs — key from Bright Data → Account settings
# → API keys (store as a secret, never commit). Scrapes run async: ChatGPT (and
# batched calls) return a snapshot_id we poll to "ready" then download.
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_PROVIDERS=chatgpt,gemini,perplexity
BRIGHT_DATA_CONCURRENCY=2
# Async snapshot polling — bump if scrapes routinely time out before "ready".
# max_polls * poll_interval = total wait per provider batch (default 10 min).
BRIGHT_DATA_POLL_INTERVAL_SECONDS=10
BRIGHT_DATA_MAX_POLLS=60
# Report the REAL Bright Data spend on the Reports page: pulls /customer/balance
# pending_balance (accrued this cycle) as the tracking cost for the current
# month, instead of the per-record estimate. Assumes this account is dedicated
# to citation tracking. Set false to use the per-record estimate instead.
BRIGHT_DATA_USE_BALANCE_COST=true
# Dataset ids from the Scrapers Library (override only if Bright Data reassigns):
# BRIGHT_DATA_DATASET_CHATGPT=gd_m7aof0k82r803d5bjm
# BRIGHT_DATA_DATASET_GEMINI=gd_mbz66arm2mf9cu856y
# BRIGHT_DATA_DATASET_PERPLEXITY=gd_m7dhdot1vw9a7gc1n

# Billing-grade API-cost rates (USD) — the cost_events ledger records each call's
# real tokens/units and computes cost from these. Set to your actual rates.
#  Anthropic: per 1,000,000 tokens (input / output); Sonnet 4.6 list by default.
#  image: per generated image; citation record: per Bright Data AI-search result.
ANTHROPIC_INPUT_COST_PER_MTOK=3.0
ANTHROPIC_OUTPUT_COST_PER_MTOK=15.0
COST_PER_IMAGE_USD=0.09
COST_PER_CITATION_RECORD_USD=0.002
# Fallback only: per-generation estimate used for months with no ledger data.
COST_PER_CONTENT_GENERATION_USD=0.12

# Self-hosted GEO/AEO Tracker (only if CITATION_PROVIDER=geo_aeo)
GEO_AEO_TRACKER_URL=http://localhost:3000
GEO_AEO_PROVIDERS=perplexity,chatgpt,google_ai
GEO_AEO_CONCURRENCY=2
CITATION_SAMPLE_RUNS=3
PEEC_API_KEY=

# Content generation — max pending queue items generated per brand, per
# daily run (default 1: exactly the 1/brand/day topic discovery queues).
CONTENT_GENERATION_MAX_PER_BRAND=1
# Publish validated drafts automatically (monitor-after model). false =
# drafts wait in Content Review for a human, as before.
AUTO_PUBLISH_ENABLED=true

# Automated topic discovery (daily 8am): mines GSC search demand + citation
# gaps + coverage gaps into the content queue.
# MAX_PER_BRAND=1 alternates trend/AEO-gap picks day-to-day (recommended
# start). MAX_PER_BRAND>=2 picks one of each, same day.
TOPIC_DISCOVERY_ENABLED=true
TOPIC_DISCOVERY_MAX_PER_BRAND=1
TOPIC_DISCOVERY_MAX_TOTAL=10
TOPIC_DISCOVERY_MIN_IMPRESSIONS=20

GOOGLE_SERVICE_ACCOUNT_JSON=
BING_API_KEY=
# Optional override of AI-assistant referrer hosts for GA4 AI-traffic segmentation.
# Defaults cover ChatGPT, Perplexity, Claude, Gemini, Copilot, DeepSeek, Grok, Meta AI.
# AI_REFERRER_HOSTS=chatgpt.com,perplexity.ai,claude.ai

# Supabase Auth (same project as DATABASE_URL)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=

# Notifications
SLACK_WEBHOOK_URL=
# Discord channel webhook (channel settings → Integrations → Webhooks →
# New Webhook → copy URL). Receives published-post notifications with the
# live links, for monitoring what went out.
DISCORD_WEBHOOK_URL=
# Production: set to your Netlify site URL (also auto-added to CORS allow list).
FRONTEND_URL=http://localhost:5173

# App
# Local dev: ENVIRONMENT=development (allows any localhost port for CORS).
# Railway/production: set ENVIRONMENT=production.
ENVIRONMENT=development
# Local dev only: allow API access without JWTs (requires ENVIRONMENT=development
# and empty SUPABASE_URL/SUPABASE_JWT_SECRET). Never enable in production.
AUTH_DEV_BYPASS=false
SECRET_KEY=change-me-in-production
# Production: comma-separated list of allowed frontend origins (your Netlify URL).
# e.g. CORS_ORIGINS=https://axxiom-aeo.netlify.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: regex to also allow Netlify deploy previews / branch deploys.
# e.g. CORS_ORIGIN_REGEX=https://([a-z0-9-]+--)?axxiom-aeo\.netlify\.app
CORS_ORIGIN_REGEX=

# NOTE: Railway provides PORT automatically — do not set it.
# Start command (railway.json / Procfile): uvicorn app.main:app --host 0.0.0.0 --port $PORT
