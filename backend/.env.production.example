# Production template for Railway — copy values into Railway Variables (never commit real secrets)

ENVIRONMENT=production
SECRET_KEY=generate-a-long-random-string

# Supabase DB (use pooler + DB_PASSWORD if password has special chars)
DATABASE_URL=postgresql://postgres.cdlssoeqqfrgckpxewhn:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
DB_SCHEMA=aeo
SUPABASE_PROJECT_REF=cdlssoeqqfrgckpxewhn
SUPABASE_DB_REGION=aws-1-ap-northeast-1
DB_PASSWORD="your-quoted-password-if-needed"

# Supabase Auth
SUPABASE_URL=https://cdlssoeqqfrgckpxewhn.supabase.co
