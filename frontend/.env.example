# Frontend environment variables (Vite — must be prefixed with VITE_).
# Local dev: copy to .env. Production (Netlify): set these in
# Site settings → Environment variables (do NOT commit real values).

# URL of the deployed FastAPI backend (Railway). No trailing slash.
# Local dev example: http://localhost:8000
VITE_API_URL=https://your-backend.up.railway.app

# Supabase project (auth). Same project the backend uses.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
